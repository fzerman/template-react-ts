{
    "name": "mafia-game-server",
    "version": "0.1.0",
    "description": "REST API backend for the Mafia game",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:migrate": "npx sequelize-cli db:migrate",
        "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
        "db:seed": "npx sequelize-cli db:seed:all",
        "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@adminjs/express": "^6.1.1",
        "@adminjs/sequelize": "^4.1.1",
        "@sequelize/postgres": "7.0.0-alpha.46",
        "adminjs": "^7.8.17",
        "bcryptjs": "3.0.2",
        "connect-session-sequelize": "^8.0.6",
        "cors": "2.8.5",
        "dotenv": "16.6.1",
        "express": "5.1.0",
        "express-async-handler": "1.2.0",
        "express-formidable": "^1.2.0",
        "express-rate-limit": "8.3.2",
        "express-session": "^1.19.0",
        "helmet": "8.1.0",
        "jsonwebtoken": "9.0.2",
        "node-cron": "4.1.0",
        "passport": "0.7.0",
        "passport-jwt": "4.0.1",
        "pg": "8.16.3",
        "pino": "10.1.0",
        "redis": "5.8.1",
        "sequelize": "6.37.7",
        "socket.io": "4.8.3",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "2.4.6",
        "@types/cors": "2.8.17",
        "@types/express": "5.0.0",
        "@types/express-session": "^1.18.2",
        "@types/jsonwebtoken": "9.0.7",
        "@types/node": "22.13.10",
        "@types/node-cron": "3.0.11",
        "sequelize-cli": "6.6.2",
        "tsx": "4.19.3",
        "typescript": "5.7.2",
        "vitest": "^4.1.4"
    }
}
