# Server
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mafia_game
DB_USER=mafia
DB_PASSWORD=mafia

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PUBLISHER_JWT_SECRET=change-me-publisher-secret

# Game Phase Durations (seconds)
PHASE_DAY_DISCUSSION_SECONDS=120
PHASE_DAY_VOTING_SECONDS=60
PHASE_NIGHT_SECONDS=45

# Game Limits
MIN_PLAYERS=6
MAX_PLAYERS=15

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_GENERAL=100

# AdminJS
ADMIN_EMAIL=admin@mafia.local
ADMIN_PASSWORD=change-me-in-production
ADMIN_COOKIE_SECRET=change-me-cookie-secret
